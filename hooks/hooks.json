{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/log_event.py\""
          }
        ]
      }
    ]
  }
}
